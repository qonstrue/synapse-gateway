          "title": "All metric names for job=$job (if empty, check the ServiceMonitor / scrape config)",
          "type": "table"
        }
      ]
    },
    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 1 }, "id": 10, "title": "Traffic", "type": "row", "panels": [] },
